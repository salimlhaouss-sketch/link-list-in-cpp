#include <stdio.h>
#include <math.h>
 int echange (int *x, int *y ) {
     int d; 
        d = *x;
        *x = *y;
        *y = d;
    return 0;
};
 int main() {
    int a = 1, b = 2;
    
    printf ("%d %d\n", a, b);
    echange( &a, &b);

    printf("ba3d l3amaliya : a = %d, b = %d\n", a, b);
    
    return 0;
}


