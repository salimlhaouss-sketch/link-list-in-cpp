#include <stdio.h>
#include <time.h>
#include <unistd.h>
#include <stdbool.h>

int main() {

    time_t rawtime;
    struct tm *timeinfo;
    bool isRunning = true;

    printf("DIGITAL CLOCK\n\n");

    while(isRunning){

        time(&rawtime);                  
        timeinfo = localtime(&rawtime); //
               timeinfo->tm_hour,
               timeinfo->tm_min,
               timeinfo->tm_sec;

        sleep(1);
    }

    return 0;
}