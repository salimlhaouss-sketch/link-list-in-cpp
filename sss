#include <stdalign.h>
#include <iostream>
#include <string>
#include <iostream>

int main(){

    int tab[] = {1,3,2,6,4,5,8,7,9,10};
    int size = sizeof(tab)/sizeof(tab[0]);

    for(int i = 0; i < size; i++){
        for(int j = 0; j < size; j++){

            if(tab[i] < tab[j]){
                int temp = tab[i];
                tab[i] = tab[j];
                tab[j] = temp;
            }

        }
    }

    for(int i = 0; i < size; i++){
        std::cout << tab[i] << " ";
    }

    return 0;
}